{
  "rewrites": [
    {
      "source": "/hf-api/:match*",
      "destination": "https://router.huggingface.co/:match*"
    },
    {
      "source": "/groq-api/:match*",
      "destination": "https://api.groq.com/:match*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
